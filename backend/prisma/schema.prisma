// Prisma schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  EMPLOYER
  EMPLOYEE
}

enum ShiftType {
  MORNING
  AFTERNOON
  NIGHT
}

model User {
  id String @id @default(uuid())
  email String @unique
  passwordHash String
  role Role
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employee Employee?
}

model Employee {
  id String @id @default(uuid())
  userId String @unique
  firstName String
  lastName String
  phone String?
  position String?
  avatar String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  availabilities Availability[]
  scheduleEntries ScheduleEntry[]
}

model Availability {
  id String @id @default(uuid())
  employeeId String
  date DateTime @db.Date
  shiftType ShiftType 
  isAvailable Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, date, shiftType]) 
}

model ScheduleEntry {
  id String @id @default(uuid())
  employeeId String
  date DateTime @db.Date
  shiftType ShiftType 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  employee Employee @relation(fields: [employeeId], references: [id])
  @@unique([employeeId, date, shiftType])

}