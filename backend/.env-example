# Server — loaded via --env-file flag in dev script
PORT=3000

# Database — must match values in compose.yml
POSTGRES_USER=root
POSTGRES_PASSWORD=root
POSTGRES_DB=employee_scheduling
POSTGRES_PORT=5433

# Prisma reads this to connect to PostgreSQL
DATABASE_URL=postgresql://root:root@localhost:5433/employee_scheduling

# pgAdmin
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin
PGADMIN_PORT=8080

# Auth — used to sign and verify JWT tokens
JWT_SECRET=change-me-to-something-secret

# Logging — Winston format switches on NODE_ENV ('production' is JSON, otherwise pretty-printed).
# Default log level is 'debug' in dev, 'info' in production.
# Set LOG_LEVEL to override (e.g. LOG_LEVEL=info to quiet the dev terminal).
NODE_ENV=development
